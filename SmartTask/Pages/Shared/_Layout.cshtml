<!DOCTYPE html>
<html lang="da">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SmartTask</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
</head>
<body>

    <header>
        <nav class="navbar">
            <div class="container">
                <a class="navbar-brand" asp-page="/Index">
                    <span class="navbar-dot"></span>
                    SmartTask
                </a>
                <ul class="navbar-nav flex-row align-items-center gap-4 ms-auto">
                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        <li class="nav-item">
                            <a class="nav-link @(ViewData["Title"]?.ToString() == "SmartTask" ? "nav-link-active" : "")" asp-page="/Index">Hjem</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(ViewData["Title"]?.ToString() == "Dashboard" ? "nav-link-active" : "")" asp-page="/Dashboard">Dashboard</a>
                        </li>
                        <li class="nav-item">
                            <form method="post" asp-page="/Logout">
                                <button type="submit" class="nav-link">Log ud</button>
                            </form>
                        </li>
                        <li class="nav-item">
                            <span class="navbar-avatar">@User.Identity.Name[0].ToString().ToUpper()</span>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link @(ViewData["Title"]?.ToString() == "Log ind" ? "nav-link-active" : "")" asp-page="/Login">Log ind</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(ViewData["Title"]?.ToString() == "Opret konto" ? "nav-link-active" : "")" asp-page="/Register">Opret konto</a>
                        </li>
                    }
                </ul>
            </div>
        </nav>
    </header>

    <main>
        @RenderBody()
    </main>

    <footer>
        <div class="container">
            <p>&copy; 2026 SmartTask</p>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>