@page "{id:int}"
@model SmartTask.Pages.EditTaskModel
@{
    ViewData["Title"] = "Rediger opgave";
}

<div class="auth-wrapper">
    <div class="auth-card" style="max-width: 550px;">

        <div class="auth-header">
            <h1>Rediger opgave</h1>
            <p>Opdater oplysningerne om din opgave</p>
        </div>

        <form method="post">
            <input type="hidden" name="TaskId" value="@Model.TaskId" />
            <div class="form-group">
                <label for="title">Titel</label>
                <input type="text" id="title" name="title"
                       value="@Model.Title"
                       placeholder="Hvad skal gøres?" />
            </div>
            <div class="form-group">
                <label for="description">Beskrivelse</label>
                <textarea id="description" name="description"
                          placeholder="Valgfri beskrivelse...">@Model.Description</textarea>
            </div>
            <div class="form-group">
                <label for="deadline">Deadline</label>
                <input type="date" id="deadline" name="deadline"
                       value="@Model.Deadline?.ToString("yyyy-MM-dd")" />
            </div>
            <div class="form-group">
                <label for="priority">Prioritet</label>
                <select id="priority" name="priority">
                    @if (Model.Priority == SmartTask.Models.Priority.Low)
                    {
                        <option value="Low" selected>Lav</option>
                        <option value="Medium">Medium</option>
                        <option value="High">Høj</option>
                    }
                    else if (Model.Priority == SmartTask.Models.Priority.Medium)
                    {
                        <option value="Low">Lav</option>
                        <option value="Medium" selected>Medium</option>
                        <option value="High">Høj</option>
                    }
                    else
                    {
                        <option value="Low">Lav</option>
                        <option value="Medium">Medium</option>
                        <option value="High" selected>Høj</option>
                    }
                </select>
            </div>
            <div class="form-group">
                <label for="status">Status</label>
                <select id="status" name="status">
                    @if (Model.Status == SmartTask.Models.Status.NotStarted)
                    {
                        <option value="NotStarted" selected>Ikke startet</option>
                        <option value="InProgress">Igangværende</option>
                        <option value="Done">Færdig</option>
                    }
                    else if (Model.Status == SmartTask.Models.Status.InProgress)
                    {
                        <option value="NotStarted">Ikke startet</option>
                        <option value="InProgress" selected>Igangværende</option>
                        <option value="Done">Færdig</option>
                    }
                    else
                    {
                        <option value="NotStarted">Ikke startet</option>
                        <option value="InProgress">Igangværende</option>
                        <option value="Done" selected>Færdig</option>
                    }
                </select>
            </div>

            @if (Model.ErrorMessage != null)
            {
                <div class="auth-error">
                    @Model.ErrorMessage
                </div>
            }

            <button type="submit" class="btn-primary btn-full">Gem ændringer</button>
        </form>

        <div class="auth-footer">
            <p><a asp-page="/Dashboard">Tilbage til dashboard</a></p>
        </div>

    </div>
</div>